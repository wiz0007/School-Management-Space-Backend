spring.application.name=school-management-api
server.port=${SERVER_PORT:8080}

server.error.include-message=never
server.error.include-binding-errors=never
server.error.include-stacktrace=never
server.error.include-exception=false

app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:4200,http://127.0.0.1:4200}
app.security.rate-limit-capacity=${RATE_LIMIT_CAPACITY:120}
app.security.rate-limit-window=${RATE_LIMIT_WINDOW:1m}
app.security.jwt-secret=${JWT_SECRET:replace-this-with-a-long-random-secret}
app.security.jwt-expiration=${JWT_EXPIRATION:15m}
app.security.jwt-refresh-expiration=${JWT_REFRESH_EXPIRATION:7d}
app.security.auth-cookie-name=${AUTH_COOKIE_NAME:schoolsys_session}
app.security.refresh-cookie-name=${AUTH_REFRESH_COOKIE_NAME:schoolsys_refresh}
app.security.auth-cookie-secure=${AUTH_COOKIE_SECURE:false}
app.security.login-failure-window=${LOGIN_FAILURE_WINDOW:15m}
app.security.login-email-failure-limit=${LOGIN_EMAIL_FAILURE_LIMIT:5}
app.security.login-ip-failure-limit=${LOGIN_IP_FAILURE_LIMIT:20}
app.security.email-verification-expiration=${EMAIL_VERIFICATION_EXPIRATION:24h}
app.security.password-reset-expiration=${PASSWORD_RESET_EXPIRATION:30m}
app.security.public-frontend-url=${PUBLIC_FRONTEND_URL:http://localhost:4200}
app.security.account-token-dev-delivery-enabled=${ACCOUNT_TOKEN_DEV_DELIVERY_ENABLED:false}

spring.jpa.open-in-view=false
spring.jpa.hibernate.ddl-auto=${JPA_DDL_AUTO:update}
spring.jpa.show-sql=${JPA_SHOW_SQL:false}
spring.jpa.properties.hibernate.format_sql=${JPA_FORMAT_SQL:false}
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

spring.datasource.url=${DATABASE_URL:jdbc:postgresql://localhost:5432/school_management}
spring.datasource.username=${DATABASE_USERNAME:postgres}
spring.datasource.password=${DATABASE_PASSWORD:replace-this-locally}
spring.datasource.hikari.maximum-pool-size=${DB_POOL_SIZE:10}
spring.datasource.hikari.minimum-idle=${DB_MIN_IDLE:1}
spring.datasource.hikari.connection-timeout=${DB_CONNECTION_TIMEOUT:30000}
spring.datasource.hikari.initialization-fail-timeout=${DB_INITIALIZATION_FAIL_TIMEOUT:0}
